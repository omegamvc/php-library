{
    "name": "omegamvc/php-library",
    "description": "This is a library to build php mvc",
    "keywords": [
        "framework",
        "php-mvc",
        "php-library"
    ],
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Adriano Giovannini",
            "email": "agisoftt@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-http": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-pcntl": "*",
        "ext-pdo": "*",
        "ext-posix": "*",
        "ext-readline": "*",
        "php-di/php-di": "^7.0.9"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "3.11.3"
    },
    "autoload": {
        "psr-4": {
            "System\\": "src/System/"
        },
        "files": [
            "src/System/Application/helper.php",
            "src/System/Collection/helper.php",
            "src/System/Console/helper.php",
            "src/System/Text/helper.php",
            "src/System/Time/helper.php",
            "src/System/Validator/helper.php"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
